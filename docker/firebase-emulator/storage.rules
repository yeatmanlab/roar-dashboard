rules_version = '2';

// Rules for the LOCAL Firebase Storage emulator only.
//
// Loaded solely by docker/firebase-emulator/firebase.json's `storage` block when the
// emulator suite runs in dev. Production/staging recordings go to the admin-project
// buckets (gs://roar-admin-recordings-{prod,staging}) which enforce their own rules;
// this file is never deployed there.
//
// Assessments sign in anonymously, so allow any authenticated session to read/write
// recordings under the emulator. This is intentionally permissive because it is local,
// throwaway emulator data with no real credentials.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
