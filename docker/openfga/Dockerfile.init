# Lightweight init container that creates an OpenFGA store and deploys the
# authorization model on first boot. Uses the FGA CLI from the official
# openfga/cli image (which is distroless) copied into an Alpine base that
# provides bash and jq for scripting.
FROM openfga/cli:v0.7.2 AS cli

FROM alpine:3.22
RUN apk add --no-cache bash jq curl
COPY --from=cli /fga /usr/local/bin/fga
COPY init-store.sh /init-store.sh
RUN chmod +x /init-store.sh
ENTRYPOINT ["bash", "/init-store.sh"]
