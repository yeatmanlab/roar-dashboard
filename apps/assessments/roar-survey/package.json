{
  "name": "@bdelab/roar-survey",
  "version": "0.2.2",
  "main": "./lib/roar-survey.umd.js",
  "module": "./lib/roar-survey.es.js",
  "type": "module",
  "files": [
    "lib"
  ],
  "exports": {
    ".": {
      "import": "./lib/roar-survey.es.js",
      "require": "./lib/roar-survey.umd.js"
    },
    "./lib/*.css": {
      "import": "./lib/*.css",
      "require": "./lib/*.css"
    }
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build:dev": "vite build --mode development",
    "build:staging": "vite build --mode staging",
    "build:prod": "vite build --mode production",
    "package": "vite build --mode lib",
    "preview": "vite preview",
    "version": "git add -A",
    "postversion": "GIT_REMOTE=$(git remote -v | grep \"yeatmanlab/roar-survey-app.git \\(push\\)\" | cut -f 1) && git push $GIT_REMOTE && git push $GIT_REMOTE --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yeatmanlab/roar-survey-app.git"
  },
  "license": "STANFORD ACADEMIC SOFTWARE LICENSE FOR ROAR™",
  "dependencies": {
    "@bdelab/roar-firekit": "^9.8.0",
    "regenerator-runtime": "^0.14.1",
    "survey-core": "^2.0.8",
    "survey-vue3-ui": "^2.0.8"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "vite": "^6.3.5"
  }
}
