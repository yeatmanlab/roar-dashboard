{
  "name": "@roar-platform/roar-survey",
  "version": "0.2.2",
  "main": "./lib/roar-survey.umd.js",
  "module": "./lib/roar-survey.es.js",
  "type": "module",
  "files": [
    "lib"
  ],
  "exports": {
    ".": {
