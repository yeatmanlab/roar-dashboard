{
  "name": "@roar-platform/roar-survey",
  "version": "0.2.2",
  "main": "./lib/roar-survey.umd.js",
  "module": "./lib/roar-survey.es.js",
  "type": "module",
  "files": [
    "lib"
  ],
  "exports": {
    ".": {
      "import": "./lib/roar-survey.es.js",
      "require": "./lib/roar-survey.umd.js"
    },
    "./lib/*.css": {
      "import": "./lib/*.css",
      "require": "./lib/*.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "roar": {
    "hosting": {
      "staging": "roar-survey-monorepo-abc",
      "production": "roar-survey-monorepo"
    }
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "scripts": {
    "dev": "bash ../../../scripts/dev-platform.sh",
    "dev:ci": "npx vite --mode development --port 8000",
    "setup": "bash ../../../scripts/assessment-setup.sh",
    "start": "bash ../../../scripts/assessment-env-up.sh",
    "seed:tasks": "bash ../../../scripts/assessment-seed-tasks.sh",
    "stop": "bash ../../../scripts/assessment-env-down.sh",
    "restart": "bash ../../../scripts/assessment-restart.sh",
    "rebuild": "bash ../../../scripts/assessment-env-build.sh",
    "update": "npm --prefix ../../../packages/assessment-schema run build && npm --prefix ../../../packages/assessment-sdk run build",
    "build": "vite build --mode lib",
    "build:staging": "vite build --mode staging",
    "build:production": "vite build --mode production",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write --log-level=warn",
    "format:check": "prettier . --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yeatmanlab/roar-dashboard.git",
    "directory": "apps/assessments/roar-survey"
  },
  "license": "STANFORD ACADEMIC SOFTWARE LICENSE FOR ROAR™",
  "dependencies": {
    "@roar-platform/assessment-sdk": "^0.1.0",
    "@roar-platform/assessment-schema": "^0.1.0",
    "firebase": "^10.13.2",
    "regenerator-runtime": "^0.14.1",
    "survey-core": "^2.0.8",
    "survey-vue3-ui": "^2.0.8"
  },
  "devDependencies": {
    "@roar-platform/eslint-config": "*",
    "@roar-platform/prettier-config": "*",
    "@vitejs/plugin-vue": "^5.2.3",
    "cypress": "^13.6.4",
    "eslint": "^9.0.0",
    "eslint-plugin-cypress": "^5.1.0",
    "prettier": "^3.0.0",
    "vite": "^6.3.5"
  }
}
