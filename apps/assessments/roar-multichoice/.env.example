# Sentry source map upload token (obtain from Sentry → Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=

# ROAR backend base URL (e.g. https://api.roar.stanford.edu)
# In development, this proxies to BACKEND_URL via webpack devServer
ROAR_API_BASE_URL=

# Backend URL for the webpack dev server proxy (development only)
BACKEND_URL=http://localhost:4000

# Firebase Auth Emulator host (development only, e.g. 127.0.0.1:9099)
FIREBASE_AUTH_EMULATOR_HOST=

# Cypress project ID (overrides the hardcoded fallback in cypress.config.js)
CYPRESS_PROJECT_ID=p1ygx3
