{
  "name": "@roar-platform/roar-multichoice",
  "description": "Morphology and Written Vocabulary (CVA) multiple-choice assessments for ROAR",
  "version": "2.2.1",
  "author": "Tonya & Willy",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "roar": {
    "hosting": {
      "staging": "roar-multichoice-monorepo-abc",
      "production": "roar-multichoice-monorepo"
    }
  },
  "scripts": {
    "build": "rollup -c rollup.lib.config.mjs",
    "build:staging": "webpack --mode production --env dbmode=staging",
    "build:production": "webpack --mode production --env dbmode=production",
    "predev": "if lsof -i :8000 -sTCP:LISTEN >/dev/null 2>&1 || ss -tlnp 2>/dev/null | grep -q ':8000 '; then echo 'Error: port 8000 is already in use. Stop that process before starting the dev server.' >&2; exit 1; fi",
    "dev": "bash ../../../scripts/dev-platform.sh",
    "dev:ci": "npx webpack serve --mode development --env dbmode=development",
    "start": "bash ../../../scripts/assessment-env-up.sh",
    "update": "npm --prefix ../../../packages/scoring-tables run build && npm --prefix ../../../packages/assessment-schema run build && npm --prefix ../../../packages/assessment-sdk run build",
    "stop": "bash ../../../scripts/assessment-env-down.sh",
    "restart": "npm run stop && npm run start",
    "rebuild": "bash ../../../scripts/assessment-env-build.sh",
    "test": "vitest --run --passWithNoTests",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write --log-level=warn",
    "format:check": "prettier . --check",
    "cypress:open": "cypress open"
  },
  "license": "STANFORD ACADEMIC SOFTWARE LICENSE FOR ROAR™",
  "dependencies": {
    "@roar-platform/assessment-schema": "^0.1.0",
    "@roar-platform/assessment-sdk": "^0.1.0",
    "@roar-platform/scoring-tables": "^0.1.0",
    "@bdelab/jscat": "5.2.3",
    "@bdelab/roar-firekit": "^9.6.0",
    "@bdelab/roar-utils": "1.2.7",
    "@jspsych-contrib/plugin-audio-multi-response": "^1.0.0",
    "@jspsych-contrib/plugin-html-multi-response": "^1.0.2",
    "@jspsych-contrib/plugin-html-swipe-response": "^1.0.0",
    "@jspsych/plugin-audio-button-response": "^1.1.2",
    "@jspsych/plugin-audio-keyboard-response": "^1.1.0",
    "@jspsych/plugin-call-function": "^1.1.2",
    "@jspsych/plugin-fullscreen": "^1.1.0",
    "@jspsych/plugin-html-keyboard-response": "^1.1.0",
    "@jspsych/plugin-preload": "^1.1.0",
    "@jspsych/plugin-survey-html-form": "^1.0.0",
    "@jspsych/plugin-survey-multi-select": "^1.1.0",
    "@jspsych/plugin-survey-text": "^1.1.0",
    "firebase": "^10.13.2",
    "detect-it": "^4.0.1",
    "fscreen": "^1.2.0",
    "i18next": "^22.4.15",
    "i18next-browser-languagedetector": "^7.0.1",
    "jspsych": "^7.2.1",
    "lodash": "^4.17.21",
    "mime-types": "^2.1.35",
    "papaparse": "^5.4.1",
    "regenerator-runtime": "^0.13.9",
    "roarr": "^7.14.0",
    "store2": "^2.13.2"
  },
  "peerDependencies": {
    "@sentry/browser": ">=7",
    "@sentry/integrations": ">=7",
    "@sentry/wasm": ">=7"
  },
  "devDependencies": {
    "@babel/core": "^7.22.5",
    "@babel/preset-env": "^7.22.5",
    "@rollup/plugin-commonjs": "^25.0.3",
    "@rollup/plugin-dsv": "^3.0.2",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.1.0",
    "@roar-platform/eslint-config": "*",
    "@roar-platform/prettier-config": "*",
    "@sentry/rollup-plugin": "^2.14.0",
    "@sentry/webpack-plugin": "^2.14.0",
    "@types/node": "^20.9.0",
    "babel-loader": "^9.1.2",
    "css-loader": "^6.7.1",
    "csv-loader": "^3.0.5",
    "cypress": "^13.6.4",
    "dotenv": "^16.4.4",
    "eslint": "^9.0.0",
    "eslint-plugin-cypress": "^5.1.0",
    "file-loader": "^6.2.0",
    "globals": "^16.0.0",
    "html-webpack-plugin": "^5.5.0",
    "path-browserify": "^1.0.1",
    "prettier": "^3.6.0",
    "process": "^0.11.10",
    "rollup": "^3.26.3",
    "rollup-plugin-esbuild": "^6.1.1",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.64.2",
    "sass-loader": "^13.3.2",
    "style-loader": "^3.3.1",
    "vitest": "^3.2.4",
    "webpack": "^5.70.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "webpack-merge": "^5.8.0"
  },
  "browser": {
    "crypto": false
  }
}
