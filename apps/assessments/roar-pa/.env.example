SENTRY_AUTH_TOKEN=

# ROAR backend server root URL. The /v1 version prefix is appended automatically.
# Required in production builds to point at the Cloud Run backend.
ROAR_API_URL=

# -------------------------------------------------------------------------------------------------------------------- #
# Local Development Overrides
# -------------------------------------------------------------------------------------------------------------------- #
# A local .env file is not required for development. The defaults below are used automatically.
# Only create a local .env and set these if you need to customize your environment.

# Dev-server proxy target for /v1 requests (default: https://localhost:4000).
# Override if your backend runs on a different port.
# BACKEND_URL=https://localhost:4000
