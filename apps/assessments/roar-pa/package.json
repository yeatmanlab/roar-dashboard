{
  "name": "@roar-dashboard/roar-pa",
  "description": "This is a 3-AFC task to measure phonological awareness",
  "version": "5.1.0",
  "author": "AnyaWMa <anyawma08@gmail.com>",
  "main": "src/index.js",
  "module": "src/index.js",
  "type": "module",
  "scripts": {
    "//": "build is a no-op: Vite resolves imports via 'main' (src/index.js) directly, so no webpack output is needed for dashboard#dev. Use build:staging or build:prod for CI deployments.",
    "build": "echo 'roar-pa: skipped (Vite uses src directly)'",
    "build:dev": "npx webpack --mode production --env dbmode=development",
    "build:staging": "npx webpack --mode production --env dbmode=staging",
    "build:prod": "npx webpack --mode production --env dbmode=production",
    "predev": "fkill :8000 -f || true",
    "dev": "npx webpack serve --open --mode development --env dbmode=development",
    "preserve:prod": "fkill :8000 -f || true",
    "serve:prod": "npx webpack serve --open --mode development --env dbmode=production",
    "researcher-environment:up": "concurrently --kill-others-on-fail --names emulator,backend,pa --prefix-colors cyan,yellow,green \"firebase emulators:start --only auth --project demo-roar --config ../shared/firebase.json\" \"cd ../../../apps/backend && NODE_ENV=development GOOGLE_CLOUD_PROJECT=demo-roar CORE_DATABASE_URL=postgresql://postgres@localhost:5432/roar_core ASSESSMENT_DATABASE_URL=postgresql://postgres@localhost:5432/roar_assessment FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 npm run dev\" \"docker compose -f ../../../docker-compose.yml run --rm -T researcher-db-migrate && npm run dev\"",
    "researcher-environment:down": "docker compose -f ../../../docker-compose.yml down -v",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write --log-level=warn",
    "format:check": "prettier . --check",
    "cypress:open": "cypress open"
  },
  "license": "STANFORD ACADEMIC SOFTWARE LICENSE FOR ROAR™",
  "dependencies": {
    "@roar-dashboard/assessment-schema": "*",
    "@yeatmanlab/assessment-sdk": "*",
    "@bdelab/jscat": "^5.2.2",
    "@bdelab/roar-utils": "^1.2.2",
    "@jspsych-contrib/plugin-html-multi-response": "^1.0.0",
    "@jspsych/plugin-audio-button-response": "^1.1.2",
    "@jspsych/plugin-audio-keyboard-response": "^1.1.1",
    "@jspsych/plugin-call-function": "^1.1.2",
    "@jspsych/plugin-fullscreen": "^1.1.1",
    "@jspsych/plugin-html-button-response": "^1.1.2",
    "@jspsych/plugin-html-keyboard-response": "^1.1.1",
    "@jspsych/plugin-preload": "^1.1.1",
    "@jspsych/plugin-survey-html-form": "^1.0.2",
    "@jspsych/plugin-survey-multi-select": "^1.1.2",
    "@jspsych/plugin-survey-text": "^1.1.1",
    "@sentry/browser": "^7.100.1",
    "@sentry/integrations": "^7.101.1",
    "@sentry/wasm": "^7.100.1",
    "firebase": "^10.5.0",
    "i18next": "^23.10.1",
    "i18next-browser-languagedetector": "^7.1.0",
    "jspsych": "^7.3.0",
    "lodash": "^4.17.21",
    "papaparse": "^5.3.2",
    "regenerator-runtime": "^0.13.9",
    "roarr": "^7.14.0",
    "store2": "^2.14.2"
  },
  "devDependencies": {
    "@roar-dashboard/eslint-config": "*",
    "@roar-dashboard/prettier-config": "*",
    "@types/node": "^20.9.0",
    "cypress": "^13.6.4",
    "eslint": "^9.0.0",
    "eslint-plugin-cypress": "^5.1.0",
    "folder-hash": "^4.0.2",
    "globals": "^16.0.0"
  }
}
