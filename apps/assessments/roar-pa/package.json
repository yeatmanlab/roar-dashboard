{
  "name": "@roar-dashboard/roar-pa",
  "description": "This is a 3-AFC task to measure phonological awareness",
  "version": "5.1.0",
  "author": "AnyaWMa <anyawma08@gmail.com>",
  "main": "src/index.js",
  "module": "src/index.js",
  "type": "module",
  "scripts": {
    "//": "build is a no-op: Vite resolves imports via 'main' (src/index.js) directly, so no webpack output is needed for dashboard#dev.",
    "build": "echo 'roar-pa: skipped (Vite uses src directly)'",
    "predev": "if lsof -i :8000 -sTCP:LISTEN >/dev/null 2>&1 || ss -tlnp 2>/dev/null | grep -q ':8000 '; then echo 'Error: port 8000 is already in use. Stop that process before starting the dev server.' >&2; exit 1; fi",
    "dev": "bash ../../../scripts/dev-platform.sh",
    "dev:ci": "npx webpack serve --mode development --env dbmode=development",
    "assessment-environment:up": "bash ../../../scripts/assessment-env-up.sh",
    "assessment-environment:down": "docker compose -f ../../../docker-compose.assessment.yml down -v",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write --log-level=warn",
    "format:check": "prettier . --check",
    "cypress:open": "cypress open"
  },
  "license": "STANFORD ACADEMIC SOFTWARE LICENSE FOR ROAR™",
  "dependencies": {
    "@roar-dashboard/assessment-schema": "*",
    "@yeatmanlab/assessment-sdk": "*",
    "@bdelab/jscat": "^5.2.2",
    "@bdelab/roar-utils": "^1.2.2",
    "@jspsych-contrib/plugin-html-multi-response": "^1.0.0",
    "@jspsych/plugin-audio-button-response": "^1.1.2",
    "@jspsych/plugin-audio-keyboard-response": "^1.1.1",
    "@jspsych/plugin-call-function": "^1.1.2",
    "@jspsych/plugin-fullscreen": "^1.1.1",
    "@jspsych/plugin-html-button-response": "^1.1.2",
    "@jspsych/plugin-html-keyboard-response": "^1.1.1",
    "@jspsych/plugin-preload": "^1.1.1",
    "@jspsych/plugin-survey-html-form": "^1.0.2",
    "@jspsych/plugin-survey-multi-select": "^1.1.2",
    "@jspsych/plugin-survey-text": "^1.1.1",
    "@sentry/browser": "^7.100.1",
    "@sentry/integrations": "^7.101.1",
    "@sentry/wasm": "^7.100.1",
    "firebase": "^10.5.0",
    "i18next": "^23.10.1",
    "i18next-browser-languagedetector": "^7.1.0",
    "jspsych": "^7.3.0",
    "lodash": "^4.17.21",
    "papaparse": "^5.3.2",
    "regenerator-runtime": "^0.13.9",
    "roarr": "^7.14.0",
    "store2": "^2.14.2"
  },
  "devDependencies": {
    "@babel/core": "^7.19.0",
    "@babel/preset-env": "^7.19.0",
    "@roar-dashboard/eslint-config": "*",
    "@roar-dashboard/prettier-config": "*",
    "@sentry/webpack-plugin": "^2.14.0",
    "@types/node": "^20.9.0",
    "babel-loader": "^8.2.5",
    "concurrently": "^9.1.0",
    "firebase-tools": "^13.0.0",
    "css-loader": "^6.7.1",
    "csv-loader": "^3.0.5",
    "cypress": "^13.6.4",
    "dotenv": "^16.3.1",
    "eslint": "^9.0.0",
    "eslint-plugin-cypress": "^5.1.0",
    "file-loader": "^6.2.0",
    "folder-hash": "^4.0.2",
    "globals": "^16.0.0",
    "html-webpack-plugin": "^5.5.0",
    "path-browserify": "^1.0.1",
    "prettier": "^3.6.0",
    "process": "^0.11.10",
    "style-loader": "^3.3.1",
    "webpack": "^5.74.0",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "^4.11.0",
    "webpack-merge": "^5.8.0"
  }
}
