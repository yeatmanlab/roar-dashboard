{
  "name": "@roar-platform/roar-readaloud",
  "description": "Read Aloud — a phonics oral-reading assessment with audio/video recording and gaze estimation for ROAR",
  "version": "1.4.2",
  "author": "Aryaman Taore",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "roar": {
    "hosting": {
      "staging": "roar-readaloud-monorepo-abc",
      "production": "roar-readaloud-monorepo"
    }
  },
  "scripts": {
    "build": "rollup -c rollup.lib.config.mjs",
    "build:staging": "webpack --mode production --env dbmode=staging",
    "build:production": "webpack --mode production --env dbmode=production",
    "predev": "if lsof -i :8000 -sTCP:LISTEN >/dev/null 2>&1 || ss -tlnp 2>/dev/null | grep -q ':8000 '; then echo 'Error: port 8000 is already in use. Stop that process before starting the dev server.' >&2; exit 1; fi",
    "dev": "bash ../../../scripts/dev-platform.sh",
    "dev:ci": "npx webpack serve --mode development --env dbmode=development",
    "start": "bash ../../../scripts/assessment-env-up.sh",
    "update": "npm --prefix ../../../packages/assessment-schema run build && npm --prefix ../../../packages/assessment-sdk run build",
    "stop": "bash ../../../scripts/assessment-env-down.sh",
    "restart": "npm run stop && npm run start",
    "rebuild": "bash ../../../scripts/assessment-env-build.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write --log-level=warn",
    "format:check": "prettier . --check",
    "test": "vitest --run --passWithNoTests",
    "cypress:open": "cypress open"
  },
  "license": "STANFORD ACADEMIC SOFTWARE LICENSE FOR ROAR™",
  "dependencies": {
    "@bdelab/jscat": "^4.0.0",
    "@bdelab/roar-utils": "^1.2.8",
    "@jspsych-contrib/plugin-audio-multi-response": "^1.0.0",
    "@jspsych/plugin-audio-button-response": "^1.1.2",
    "@jspsych/plugin-audio-keyboard-response": "^1.1.0",
    "@jspsych/plugin-call-function": "^1.1.2",
    "@jspsych/plugin-fullscreen": "^1.1.0",
    "@jspsych/plugin-html-button-response": "^1.2.0",
    "@jspsych/plugin-html-keyboard-response": "^1.1.3",
    "@jspsych/plugin-image-button-response": "^1.2.0",
    "@jspsych/plugin-preload": "^1.1.0",
    "@jspsych/plugin-video-keyboard-response": "^1.1.3",
    "@jspsych/test-utils": "^1.1.2",
    "@mediapipe/face_mesh": "^0.4.1633559619",
    "@roar-platform/assessment-schema": "^0.1.0",
    "@roar-platform/assessment-sdk": "^0.1.0",
    "@xenova/transformers": "^1.3.2",
    "firebase": "^10.13.2",
    "fscreen": "^1.2.0",
    "i18next": "^22.4.15",
    "i18next-browser-languagedetector": "^7.0.1",
    "jspsych": "^7.2.1",
    "lodash": "^4.17.21",
    "ml-regression-polynomial": "^3.0.0",
    "ndarray": "^1.0.19",
    "ndarray-ops": "^1.2.2",
    "onnxjs": "^0.1.8",
    "onnxruntime-web": "^1.17.1",
    "papaparse": "^5.4.1",
    "regenerator-runtime": "^0.13.9",
    "roarr": "^7.21.1",
    "store2": "^2.13.2",
    "web-worker": "^1.3.0"
  },
  "peerDependencies": {
    "@sentry/browser": ">=7",
    "@sentry/integrations": ">=7",
    "@sentry/wasm": ">=7"
  },
  "devDependencies": {
    "@babel/core": "^7.22.5",
    "@babel/preset-env": "^7.22.5",
    "@roar-platform/eslint-config": "*",
    "@roar-platform/prettier-config": "*",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-dsv": "^3.0.4",
    "@rollup/plugin-html": "^1.0.4",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-url": "^8.0.2",
    "@rollup/plugin-wasm": "^6.2.2",
    "@sentry/webpack-plugin": "^2.14.0",
    "@surma/rollup-plugin-off-main-thread": "^2.2.3",
    "babel-loader": "^9.1.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.7.1",
    "csv-loader": "^3.0.5",
    "cypress": "^13.15.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-plugin-cypress": "^5.1.0",
    "file-loader": "^6.2.0",
    "globals": "^16.0.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.5.0",
    "node-loader": "^2.0.0",
    "path-browserify": "^1.0.1",
    "prettier": "^3.6.0",
    "process": "^0.11.10",
    "rollup": "^4.48.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-esbuild": "^6.1.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-string": "^3.0.0",
    "sass": "^1.64.2",
    "sass-loader": "^13.3.2",
    "stream-browserify": "^3.0.0",
    "style-loader": "^3.3.1",
    "vitest": "^3.2.4",
    "webpack": "^5.74.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "webpack-merge": "^5.8.0"
  }
}
