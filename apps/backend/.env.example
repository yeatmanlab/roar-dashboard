# Database connection
# - For local development with Docker Compose (databases created automatically):
CORE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roar_core
ASSESSMENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roar_assessment

# - For remote Cloud SQL databases, use the following settings instead:
USE_CLOUDSQL_CONNECTOR=
CLOUDSQL_INSTANCE_CONNECTION_NAME=
CORE_DATABASE_NAME=
CORE_DATABASE_USER=
ASSESSMENT_DATABASE_NAME=
ASSESSMENT_DATABASE_USER=

# Auth
# - Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=demo-roar

# CORS
# Comma-separated list of allowed origins for the DEPLOYED API (e.g. the dashboard and
# assessment hosts). Required in production: the server refuses to boot if it is unset there.
# Local cross-service dev does not need this — the Vite/webpack dev server proxies /v1 to the
# backend (same-origin), so CORS does not apply. Falls back to https://localhost:5173 otherwise.
ALLOWED_ORIGINS=https://localhost:5173

# Firebase Auth emulator
# Set this to use the Firebase Auth emulator (started by docker compose) instead of a
# real Firebase project. The seed script also reads this to seed emulator users.
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# OpenFGA
# - Default Docker Compose stack runs on port 8080 without TLS.
#   FGA_STORE_ID and FGA_MODEL_ID are populated automatically by
#   the seed script (seeds/index.ts), which creates a store, deploys the model, and
#   writes the IDs back to this file.
FGA_API_URL=http://localhost:8080
FGA_STORE_ID=
FGA_MODEL_ID=
# - OIDC audience for deployed environments (dev/staging/prod).
#   When set, the FGA client uses Google identity tokens for authentication.
#   Leave blank for local development (FGA runs without auth locally).
FGA_OIDC_AUDIENCE=
