# Database connection
# - For local development, use connection strings
CORE_DATABASE_URL=
ASSESSMENT_DATABASE_URL=

# - For remote Cloud SQL databases, use the following settings
USE_CLOUDSQL_CONNECTOR=
CLOUDSQL_INSTANCE_CONNECTION_NAME=
CORE_DATABASE_NAME=
CORE_DATABASE_USER=
ASSESSMENT_DATABASE_NAME=
ASSESSMENT_DATABASE_USER=

# Auth
# - Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=

# OpenFGA
# - Run `docker compose up` then `npm run fga:init -w apps/backend` to populate these.
FGA_API_URL=https://localhost:5050
FGA_STORE_ID=
FGA_MODEL_ID=
# - OIDC audience for deployed environments (dev/staging/prod).
#   When set, the FGA client uses Google identity tokens for authentication.
#   Leave blank for local development (FGA runs without auth locally).
FGA_OIDC_AUDIENCE=
