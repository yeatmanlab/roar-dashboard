# Database connection
# - For local development, use connection strings
CORE_DATABASE_URL=
ASSESSMENT_DATABASE_URL=

# - For remote Cloud SQL databases, use the following settings
USE_CLOUDSQL_CONNECTOR=
CLOUDSQL_INSTANCE_CONNECTION_NAME=
CORE_DATABASE_NAME=
CORE_DATABASE_USER=
ASSESSMENT_DATABASE_NAME=
ASSESSMENT_DATABASE_USER=

# Auth
# - Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=

# CORS
# Comma-separated list of allowed origins for the DEPLOYED API (e.g. the dashboard and
# assessment hosts). Required in production: the server refuses to boot if it is unset there.
# Local cross-service dev does not need this — the Vite/webpack dev server proxies /v1 to the
# backend (same-origin), so CORS does not apply. Falls back to https://localhost:5173 otherwise.
ALLOWED_ORIGINS=https://localhost:5173

# - Local assessment development: set this to use the Firebase Auth emulator instead of a
#   real Firebase project. Required when running assessments with `npm run dev:platform`.
#   After adding this, restart the backend for it to take effect.
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# OpenFGA
# - Run `docker compose up` then `npm run fga:init -w apps/backend` to populate these.
FGA_API_URL=https://localhost:5050
FGA_STORE_ID=
FGA_MODEL_ID=
# - OIDC audience for deployed environments (dev/staging/prod).
#   When set, the FGA client uses Google identity tokens for authentication.
#   Leave blank for local development (FGA runs without auth locally).
FGA_OIDC_AUDIENCE=

# Bulk user import (POST /v1/users/import)
# - Firebase's modified-scrypt password-hash parameters for the Firebase project this backend
#   authenticates against. Required by the bulk-import create bin: importUsers needs pre-hashed
#   passwords. Find them in the Firebase console: Authentication → Users → ⋮ (top-right of the
#   users table) → "Password hash parameters". SIGNER_KEY and SALT_SEPARATOR are base64 strings;
#   ROUNDS and MEM_COST are integers. Each Firebase project (dev/staging/prod) has its own values.
#   Against the Auth emulator any consistent values work (e.g. the public Firebase test vector),
#   since the emulator verifies sign-in against the hash config the import call carries.
FIREBASE_SCRYPT_SIGNER_KEY=
FIREBASE_SCRYPT_SALT_SEPARATOR=
FIREBASE_SCRYPT_ROUNDS=
FIREBASE_SCRYPT_MEM_COST=
