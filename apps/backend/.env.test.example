# Docker-compose defaults for running tests locally and in CI.
# Copy to .env.test (or let CI do it) — Vitest loads .env.test via loadEnv().
# For CI, the seed script and server.ts read this via DOTENV_CONFIG_PATH.

# Test database connection strings (created by docker/postgres/init-dev-databases.sh)
CORE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roar_core_test
ASSESSMENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roar_assessment_test

# OpenFGA server (default Docker Compose stack)
FGA_API_URL=http://localhost:4010

# Firebase Auth emulator
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Google Cloud Project ID (matches the Firebase emulator project)
GOOGLE_CLOUD_PROJECT=demo-roar

# Test environment
NODE_ENV=test

# CORS origins allowed by the backend in test mode
ALLOWED_ORIGINS=http://127.0.0.1:4173
