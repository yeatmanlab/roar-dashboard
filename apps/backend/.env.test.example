# Test database connection strings.
# These databases are created automatically by the Docker init script
# (docker/postgres/init-dev-databases.sh) on first container creation.
CORE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roar_core_test
ASSESSMENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roar_assessment_test

# Google Cloud Project ID (can be any value for tests)
GOOGLE_CLOUD_PROJECT=test-project

# OpenFGA server for integration tests (default Docker Compose stack)
FGA_API_URL=http://localhost:8080
