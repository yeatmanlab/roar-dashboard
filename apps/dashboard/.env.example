# -------------------------------------------------------------------------------------------------------------------- #
# Environment Configuration
#
# Source of truth for all environment variables the dashboard supports. 
# For local development, copy this file to .env and configure the local development section. All other variables
# currently required as part of the transition are provided by the env-configs submodule (.env.development).
#
# .env overrides env-configs values in non-production modes (see vite.config.js).
# -------------------------------------------------------------------------------------------------------------------- #


# -------------------------------------------------------------------------------------------------------------------- #
# Firebase Authentication
# -------------------------------------------------------------------------------------------------------------------- #

# Required for deployed environments. When the Auth emulator is active
# (VITE_FIREBASE_EMULATOR_AUTH_HOST is set), these are replaced with
# fake credentials automatically.
VITE_FIREBASE_ADMIN_PROJECT_ID=
VITE_FIREBASE_ADMIN_API_KEY=
VITE_FIREBASE_ADMIN_AUTH_DOMAIN=


# -------------------------------------------------------------------------------------------------------------------- #
# Application Configuration
# -------------------------------------------------------------------------------------------------------------------- #

# ROAR API base URL for the ts-rest client.
VITE_ROAR_API_BASE_URL=http://localhost:4000/v1

# Auth session timeout (optional — sensible defaults)
VITE_AUTH_SESSION_TIMEOUT_IDLE_THRESHOLD=900000
VITE_AUTH_SESSION_TIMEOUT_COUNTDOWN_DURATION=60000

# TanStack Query devtools (optional — only outside development mode)
# VITE_QUERY_DEVTOOLS_ENABLED=false


# -------------------------------------------------------------------------------------------------------------------- #
# Local Development
# -------------------------------------------------------------------------------------------------------------------- #
# For local dev with the Docker dev stack, copy this file to .env and
# uncomment the line below. No Firebase vars are needed — the emulator
# uses fake credentials automatically.

# Firebase Auth emulator host
VITE_FIREBASE_EMULATOR_AUTH_HOST=127.0.0.1:9099
