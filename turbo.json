{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "envMode": "strict",
  "globalEnv": ["NODE_ENV", "MODE", "CI"],
  "globalPassThroughEnv": [
    "ASSESSMENT_DATABASE_URL",
    "CORE_DATABASE_URL",
    "DOTENV_PRIVATE_KEY_TEST",
    "DOTENV_PRIVATE_KEY_DEVELOPMENT",
    "DOTENV_PRIVATE_KEY_STAGING",
    "DOTENV_PRIVATE_KEY_PRODUCTION",
    "USE_CLOUDSQL_CONNECTOR",
    "CLOUDSQL_INSTANCE_CONNECTION_NAME",
    "CORE_DATABASE_NAME",
    "CORE_DATABASE_USER",
    "ASSESSMENT_DATABASE_NAME",
    "ASSESSMENT_DATABASE_USER",
    "LOG_LEVEL",
    "TEST_FIXTURE_FILE",
    "FGA_API_URL",
    "BACKEND_PORT",
    "BUILD_TEST_SERVER",
    "RUN_INTEGRATION_TESTS",
    "CYPRESS_BASE_URL",
    "CYPRESS_PROJECT_ID",
    "FIREBASE_AUTH_EMULATOR_HOST",
    "AUTHZ_MODEL_PATH",
    "BACKEND_URL",
    "ROAR_API_BASE_URL"
  ],
  "globalDependencies": [".env"],
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "interruptible": true,
      "passThroughEnv": [
        "CORE_DATABASE_URL",
        "ASSESSMENT_DATABASE_URL",
        "GOOGLE_CLOUD_PROJECT"
      ]
    },
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "passThroughEnv": ["SENTRY_AUTH_TOKEN"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env.test"],
      "outputs": ["coverage/**"],
      "passThroughEnv": [
        "CORE_DATABASE_URL",
        "ASSESSMENT_DATABASE_URL",
        "VITEST_PROJECT"
      ]
    },
    "@roar-platform/assessment-sdk#test": {
      "dependsOn": ["roar-backend#test", "^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "outputs": ["coverage/**"]
    },
    "format": {},
    "format:check": {},
    // ^build ensures upstream workspace packages are built before linting,
    // preventing false lint errors from unresolved imports. First run on a clean
    // checkout is slower; subsequent runs use Turbo's cache and are fast.
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:fix": {
      "dependsOn": ["^build"]
    }
  }
}
